{
  "name": "agent-core",
  "version": "0.2.0",
  "description": "Local development agent built on deepagentsjs.",
  "type": "module",
  "main": "./dist/src/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:gemma-32k": "bash scripts/start-gemma-4-32k.sh cli",
    "dev:gemma-32k:workspace": "bash scripts/start-gemma-4-32k.sh cli workspace",
    "serve": "tsx src/serve.ts",
    "serve:gemma-32k": "bash scripts/start-gemma-4-32k.sh serve",
    "serve:gemma-32k:workspace": "bash scripts/start-gemma-4-32k.sh serve workspace",
    "dev:web": "cd web && npm run dev -- --host 127.0.0.1 --port 5173",
    "dev:all": "tsx src/serve.ts & npm run dev:web",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "start:http": "node dist/src/serve.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "smoke": "tsx scripts/smoke-report.ts",
    "smoke:live": "tsx --test --test-timeout 120000 tests/smoke-live.test.ts",
    "test:e2e": "tsx --test --test-reporter spec --test-timeout 120000 --test-concurrency 1 tests/e2e/*.test.ts",
    "test:e2e:conversation": "tsx --test --test-timeout 120000 tests/e2e/e2e-conversation.test.ts",
    "test:e2e:http": "tsx --test --test-timeout 120000 tests/e2e/e2e-http.test.ts",
    "test:e2e:memory": "tsx --test --test-timeout 120000 tests/e2e/e2e-memory.test.ts",
    "test:e2e:hitl": "tsx --test --test-timeout 120000 tests/e2e/e2e-hitl.test.ts",
    "test:e2e:launch": "tsx --test --test-timeout 900000 tests/e2e/launch/launch-workflows.test.ts",
    "test:e2e:eval": "EVAL_L2=1 tsx --test --test-reporter spec --test-timeout 600000 --test-concurrency 1 tests/e2e/*.test.ts",
    "test:all": "npm test && npm run test:e2e",
    "bench:context": "tsx tests/benchmarks/context-benchmark.ts",
    "bench:launch": "EVAL_L2=1 tsx tests/e2e/launch/launch-benchmark-runner.ts",
    "bench:launch:ci": "EVAL_L2=1 tsx tests/e2e/launch/launch-benchmark-runner.ts --ci",
    "feishu:test": "tsx scripts/feishu-batch-runner.ts"
  },
  "keywords": [
    "deepagents",
    "langgraph",
    "agent",
    "typescript"
  ],
  "author": "xforg",
  "license": "ISC",
  "dependencies": {
    "@langchain/langgraph": "^1.2.7",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.4.2",
    "@lmstudio/sdk": "^1.5.0",
    "@types/node": "^25.5.2",
    "deepagents": "^1.8.8",
    "dotenv": "^17.4.0",
    "langchain": "^1.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0"
  }
}
