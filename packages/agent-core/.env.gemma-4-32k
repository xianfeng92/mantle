# Tuned for LM Studio Gemma 4 26B A4B loaded with ~32K context.
# Export a variable before running the helper script if you want to override it.

AGENT_CORE_MODEL=google/gemma-4-26b-a4b
AGENT_CORE_BASE_URL=http://127.0.0.1:1234/v1
AGENT_CORE_API_KEY=lm-studio

# Gemma works best with the compact prompt profile and deterministic decoding.
AGENT_CORE_PROMPT_PROFILE=compact
AGENT_CORE_TEMPERATURE=0

# Match a ~32K LM Studio load while leaving headroom for system prompt and tools.
AGENT_CORE_CONTEXT_WINDOW_TOKENS_HINT=28000

AGENT_CORE_AGENT_GRAPH_VERSION=v2
AGENT_CORE_WORKSPACE_MODE=repo
AGENT_CORE_DATA_DIR=.agent-core

AGENT_CORE_HTTP_HOST=127.0.0.1
AGENT_CORE_HTTP_PORT=8787

AGENT_CORE_VIRTUAL_MODE=1
AGENT_CORE_COMMAND_TIMEOUT_SEC=120
AGENT_CORE_MAX_OUTPUT_BYTES=100000
AGENT_CORE_MAX_INPUT_CHARS=20000
AGENT_CORE_MAX_OUTPUT_CHARS=80000

AGENT_CORE_LOG_LEVEL=info
AGENT_CORE_VERBOSE=1
